# Optional: set to 1 only when testing OpenNext/Workers bindings during `next dev` (see README).
# OPENNEXT_CLOUDFLARE_DEV=

# Server-only: full JSON of service account (Project settings → Service accounts → Generate key).
# Lets /api/members read Firestore when the browser is blocked by App Check or rules.
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...",...}
# Optional named DB (same as NEXT_PUBLIC if you use one):
# FIRESTORE_DATABASE_ID=

# Firebase (public web SDK — protect data with Firestore security rules)
# Authentication: enable Email/Password and Google in Firebase Console → Authentication → Sign-in method.
# Add your domains under Authentication → Settings → Authorized domains (localhost, production host).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: only if you use a named Firestore database (not "(default)")
# NEXT_PUBLIC_FIRESTORE_DATABASE_ID=

# App Check (required when Firestore enforcement is ON in Firebase Console)
# Get reCAPTCHA v3 site key from: Firebase → App Check → Register web app
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Local dev: set true, reload, copy the printed debug token → App Check → Manage debug tokens
# NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG=true

# Cloudinary — images (hero, members, podcasts, payment proofs). Donation report PDF is a static file: public/donation-report.pdf
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: “View on YouTube” button in Section 4 (your channel or playlist)
# NEXT_PUBLIC_YOUTUBE_CHANNEL_URL=https://www.youtube.com/@YourChannel
