rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /members/{memberId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).changedKeys().hasOnly(['imageUrl']);
      allow create, delete: if false;
    }

    // Donations: only backend (Admin SDK) reads/writes. No public client access (hides unpublished rows).
    match /donations/{donationId} {
      allow read, write: if false;
    }

    match /podcasts/{podcastId} {
      allow read: if true;
      allow write: if false;
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /posts/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
